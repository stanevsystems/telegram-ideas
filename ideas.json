[
  {
    "author": "Ilia Stanev",
    "date": "2021-09-17T18:38:05",
    "text": "Пабло Дискобар и Саддам Бассейн"
  },
  {
    "author": "Ilia Stanev",
    "date": "2021-09-20T02:14:32",
    "text": "Мумиёб"
  },
  {
    "author": "Сергей Новак",
    "date": "2021-10-08T11:16:56",
    "text": "Возьму фамилию Бигдатов"
  },
  {
    "author": "Сергей Новак",
    "date": "2022-06-14T15:27:39",
    "text": "Сосийские авиалинии"
  },
  {
    "author": "Ilia Stanev",
    "date": "2023-02-21T07:44:47",
    "text": "Если есть Мономах, должен быть и Стереомах.  Шапка Стереомаха."
  },
  {
    "author": "Ilia Stanev",
    "date": "2023-03-02T14:09:13",
    "text": "подъем с государственным переворотом"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2023-03-07T16:59:35",
    "text": "ограниЧень"
  },
  {
    "author": "Сергей Новак",
    "date": "2023-07-15T16:07:23",
    "text": "контенейросеть"
  },
  {
    "author": "Unknown",
    "date": "2023-08-12T23:12:53",
    "text": "Белое сухое игристое говно."
  },
  {
    "author": "Павел «Пианист» Менг",
    "date": "2023-08-12T23:48:28",
    "text": "Белое полусладкое игристое говно"
  },
  {
    "author": "Дмитрий Осипов",
    "date": "2023-10-18T17:23:32",
    "text": "ЛубриКокант"
  },
  {
    "author": "Дмитрий Осипов",
    "date": "2023-10-24T17:12:51",
    "text": "эрэкционер"
  },
  {
    "author": "Витя «Животное» Белявский",
    "date": "2024-02-06T17:12:10",
    "text": "Сергей Сквиртухов"
  },
  {
    "author": "Ilia Stanev",
    "date": "2024-02-12T16:40:41",
    "text": "копрограммное обеспечение"
  },
  {
    "author": "Илья Кудрявцев",
    "date": "2024-07-26T11:11:04",
    "text": "Балаклавиатура"
  },
  {
    "author": "Илья Кудрявцев",
    "date": "2024-07-26T18:45:38",
    "text": "Пыть-Яхуею"
  },
  {
    "author": "Unknown",
    "date": "2024-08-08T12:48:13",
    "text": "убойные кутикулы"
  },
  {
    "author": "Unknown",
    "date": "2024-08-16T09:37:27",
    "text": "джамшутинг"
  },
  {
    "author": "Илья Кудрявцев",
    "date": "2024-08-19T11:17:56",
    "text": "локальный мастер и локальная Маргарита"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2024-09-04T17:34:46",
    "text": "Рубрика"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2024-10-07T09:09:48",
    "text": "сосиска в тёще"
  },
  {
    "author": "Ilia Stanev",
    "date": "2024-12-12T14:20:48",
    "text": "А  Фуксиков уже было? Типа \"Кто такие Фуксики? - Большой большой секрет!\""
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2024-12-12T14:44:51",
    "text": "мошонник и собачий мошейник"
  },
  {
    "author": "Unknown",
    "date": "2024-12-25T11:54:55",
    "text": "название лекарства, (не знаю подходит под эту категорию «япридумал» или нет), но вот: Спрей ГРИППМЕФЕДРОН"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2024-12-26T18:53:17",
    "text": "испук"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2024-12-29T21:41:32",
    "text": "аэроидинахуй"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-01-23T15:40:06",
    "text": "шуруповрот"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2025-01-23T17:14:01",
    "text": "аллергия на цитриксовые"
  },
  {
    "author": "Дмитрий Осипов",
    "date": "2025-01-23T17:16:50",
    "text": "Grannyфилия"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-01-27T10:31:54",
    "text": "профессию крематолог"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-01-27T12:00:49",
    "text": "Вдохновился, кримпайторий"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-01-27T12:44:48",
    "text": "новогодний копроратиф"
  },
  {
    "author": "Илья Кудрявцев",
    "date": "2025-01-30T16:31:13",
    "text": "Дегенеральный директор"
  },
  {
    "author": "Илья Кудрявцев",
    "date": "2025-01-31T18:16:10",
    "text": "айти и выйти услуги"
  },
  {
    "author": "Илья Кудрявцев",
    "date": "2025-02-06T22:16:37",
    "text": "Антидепресанта Клаус"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2025-02-12T13:55:06",
    "text": "ГитПаб, хранит у себя все заказы всех клиентов, и можно прийти сказать набухай меня как на прошлой неделе"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-02-12T19:23:53",
    "text": "Жан Плов Лагман"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-02-13T11:24:48",
    "text": "шахиривзада уже была?"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-02-16T12:30:16",
    "text": "саранчайку"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-02-20T20:07:15",
    "text": "Сергений"
  },
  {
    "author": "Илья Кудрявцев",
    "date": "2025-02-20T20:08:14",
    "text": "А  Мотокультивиктор"
  },
  {
    "author": "Дмитрий Осипов",
    "date": "2025-02-20T20:41:22",
    "text": "Вротоняни"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-02-24T15:14:22",
    "text": "глорихолистерин"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-02-27T20:11:35",
    "text": "букаккинематограф"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-03-01T13:34:57",
    "text": "бабулякебаб"
  },
  {
    "author": "Илья Кудрявцев",
    "date": "2025-03-01T14:13:14",
    "text": "бланш де БрюсЛи"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-03-01T15:19:54",
    "text": "Кайфуция"
  },
  {
    "author": "Илья Кудрявцев",
    "date": "2025-03-03T17:26:54",
    "text": "гачимучные изделия"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-03-05T15:19:08",
    "text": "Калымагомеда"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-03-06T20:45:36",
    "text": "вильзевульву"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2025-03-11T17:28:53",
    "text": "ChatZPPP"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-03-21T21:11:41",
    "text": "Орган Фримен"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-03-21T21:14:51",
    "text": "додепанк рок"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-03-26T15:12:34",
    "text": "барабульбазавра"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-03-29T23:13:08",
    "text": "таракансибл"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-03-30T00:02:35",
    "text": "стафилококуня"
  },
  {
    "author": "Unknown",
    "date": "2025-04-04T18:51:40",
    "text": "Дэвид Копрофил"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-04-04T19:29:08",
    "text": "докер-спаниель"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-04-05T12:20:20",
    "text": "самотыквенное пюре"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-04-09T23:22:07",
    "text": "кишкольник"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-04-11T19:39:04",
    "text": "перепихонду"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-04-16T20:18:03",
    "text": "ебанутрию"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-04-23T17:20:04",
    "text": "фекальций"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-05-11T14:32:01",
    "text": "Карусельская местность. Извининдзя."
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-05-21T00:49:38",
    "text": "Силиконский щавель. ОбрыгансЭнРоузез."
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-05-23T21:18:56",
    "text": "Кстати говоря  куниленгвистические курсы"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2025-05-30T12:17:04",
    "text": "левое петушарье"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2025-06-20T14:19:03",
    "text": "кринжровер"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-06-23T21:02:07",
    "text": "Педофилча. И дарю его тебе на др, Рома."
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-06-24T22:49:09",
    "text": "рено капчурка"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-06-26T00:29:22",
    "text": "кунибализм"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-06-26T22:10:49",
    "text": "новую породу собак: самогончая"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-06-28T10:58:55",
    "text": "малосольный концерт"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-01T22:36:29",
    "text": "Псилоцебильбо"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-03T00:32:32",
    "text": "кастратосферу"
  },
  {
    "author": "Сергей Суранов",
    "date": "2025-07-04T13:38:08",
    "text": "в рубрике  была гульчачаковка?"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-07-09T15:02:34",
    "text": "завоёбывать"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-09T17:06:28",
    "text": "порно-двигательный аппарат"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-13T21:10:46",
    "text": "люлякебабочку и Надежду Люлякебабкину. И вспомнил Шахеризадницу."
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-18T15:01:01",
    "text": "бигудилдо"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2025-07-18T17:22:51",
    "text": "cumкулятор"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-19T17:17:13",
    "text": "Сегодня вдруг , что Газпром Недра надо обязательно открыть филиал в Чили."
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-22T08:59:27",
    "text": "зачем-то Дженифер Лох-Несс"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-23T20:47:27",
    "text": "чингачгусли"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-25T23:16:19",
    "text": "плавчихуахую"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-28T14:36:02",
    "text": "саранчайник"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-28T21:43:58",
    "text": "Se la Vin"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-29T20:32:27",
    "text": "Бдсэмьюайса Геймджи"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-07-31T10:11:28",
    "text": "Сережу Хэндэхохрина"
  },
  {
    "author": "Сергей Суранов",
    "date": "2025-08-01T18:03:59",
    "text": "рубрику  пополнили мои текущие коллеги с Дикпиковой Дамой"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-08-17T18:08:48",
    "text": "БредПитт-байк"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-09-03T22:11:43",
    "text": "кунитаз и neo-дачников"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-09-07T17:38:09",
    "text": "«Gang» Bank, или АО «Ганг» банк."
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-09-07T23:19:46",
    "text": "город Пискоструйск"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-09-10T20:55:56",
    "text": "сискастинг"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-09-10T22:17:19",
    "text": "А  ассартистка"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-09-15T18:56:55",
    "text": "овечку Галоперидолли"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-09-15T20:29:21",
    "text": "поллюционер"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-09-17T20:08:41",
    "text": "Блогеры доросли то моего  20-ти летней давности"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-09-23T09:31:37",
    "text": "шерстяные соски"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-09-23T22:11:56",
    "text": "@MarksBlooded  Что Enigma - это аудио-смазка"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2025-09-25T10:28:10",
    "text": "барбекюль пуаро"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-09-30T06:52:17",
    "text": "просрочество"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-10-01T22:40:34",
    "text": "Кыш-Папая"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-10-03T15:41:19",
    "text": "Мне кажется,  страну Вагинистан"
  },
  {
    "author": "Валижульен Джамалутинов",
    "date": "2025-10-03T21:38:40",
    "text": "клиторно-сладкий"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-10-03T21:48:52",
    "text": "А  не такое веселое, но Ебучего Голландца"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-10-07T20:42:57",
    "text": "пару имен: Геркулепс и Откатий."
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-10-08T08:57:53",
    "text": "чепушильдик"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-10-08T21:23:40",
    "text": "ну, погодилдо"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-10-10T15:09:45",
    "text": "братьев: Карабаса-Пидараса и Пидараса-Барабаса"
  },
  {
    "author": "Валижульен Джамалутинов",
    "date": "2025-10-11T21:52:29",
    "text": "шлюхофрукты"
  },
  {
    "author": "Сергей Суранов",
    "date": "2025-10-11T22:13:52",
    "text": "учёные гачимученые"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2025-10-13T12:05:08",
    "text": "кагарманные деньги"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-10-16T13:35:17",
    "text": "влажная задача"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-10-17T08:33:15",
    "text": "У меня там брат  мужеложные опята"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2025-10-21T20:09:10",
    "text": "А уже было  пиздата саентист?"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-10-22T14:59:09",
    "text": "ягоду хрюкву и Мастурбекхема"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-10-27T14:30:31",
    "text": "татарочник"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-10-31T09:07:13",
    "text": "дикпиковая дама уже была?"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-11-18T21:51:57",
    "text": "эректобус"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-11-23T13:07:38",
    "text": "камасутренник"
  },
  {
    "author": "Артем «Амёбушек» Акъюлов",
    "date": "2025-11-28T15:49:52",
    "text": "садо-мазь для спины"
  },
  {
    "author": "Ilia Stanev",
    "date": "2025-11-30T20:08:15",
    "text": "чайную мужеложечку"
  },
  {
    "author": "Сергей Новак",
    "date": "2025-12-05T10:03:23",
    "text": "мочевидно"
  },
  {
    "author": "Сергей Суранов",
    "date": "2025-12-06T11:26:44",
    "text": "огородный куколд"
  },
  {
    "author": "Роман «Гонщик» Дюпин",
    "date": "2025-12-13T12:04:01",
    "text": "Полюциус Малфой"
  },
  {
